# Example environment configuration for AtomSculptor
# Copy this file to .env and fill in your actual values

# =============================================================================
# AtomSculptor Configuration
# =============================================================================

# Model used by agents (can override in config.yaml)
PLANNER_MODEL=openai/qwen3-max
STRUCTURE_BUILDER_MODEL=openai/qwen3-max
MP_SEARCHER_MODEL=openai/qwen3-max
CODE_ANALYZER_MODEL=openai/qwen3-max

# Sandbox directory for runtime wrapper
SANDBOX_DIR=sandbox/runtime

# =============================================================================
# Code-Graph-RAG / Memgraph Configuration
# =============================================================================

# Memgraph connection settings
MEMGRAPH_HOST=localhost
MEMGRAPH_PORT=7687
MEMGRAPH_HTTP_PORT=7444
LAB_PORT=3000

# LLM Provider for code-graph-rag
# Options: gemini, deepseek, local, openai
LLM_PROVIDER=openai

# Gemini Provider (if using Gemini)
# Options: gla (API), vertex (Vertex AI)
GEMINI_PROVIDER=gla

# =============================================================================
# API Keys
# =============================================================================

# Materials Project API Key (for mp_searcher agent)
# Get your key from: https://next-gen.materialsproject.org/api
MP_API_KEY=your_mp_api_key_here

# OpenAI API Key (if using OpenAI models)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1

# DeepSeek API Key (if using DeepSeek)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Gemini API Key (if using Gemini with gla provider)
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# GCP Configuration (if using Vertex AI)
# =============================================================================

GCP_PROJECT_ID=your_gcp_project_id
GCP_REGION=us-central1
GCP_SERVICE_ACCOUNT_FILE=/path/to/service-account.json

# =============================================================================
# Model IDs (Advanced Configuration)
# =============================================================================

# Gemini models
GEMINI_MODEL_ID=gemini-2.5-pro
GEMINI_VISION_MODEL_ID=gemini-2.5-flash
MODEL_CYPHER_ID=gemini-2.5-flash-lite-preview-06-17
GEMINI_THINKING_BUDGET=

# DeepSeek models
DEEPSEEK_MODEL_ID=deepseek-chat

# OpenAI-compatible models (works for qwen3-max endpoints)
OPENAI_ORCHESTRATOR_MODEL_ID=qwen3-max
OPENAI_CYPHER_MODEL_ID=qwen3-max

# Local Ollama models
LOCAL_MODEL_ENDPOINT=http://localhost:11434/v1
LOCAL_ORCHESTRATOR_MODEL_ID=llama3
LOCAL_CYPHER_MODEL_ID=llama3
LOCAL_MODEL_API_KEY=ollama

# =============================================================================
# Code Analysis Configuration
# =============================================================================

# Target repository path for code analysis (optional, defaults to current workspace)
TARGET_REPO_PATH=

# Shell command timeout for code operations (seconds)
SHELL_COMMAND_TIMEOUT=30
